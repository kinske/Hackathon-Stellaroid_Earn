NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Fill in once your contract is deployed to testnet.
# Current public trust-layer contract (2026-05 security baseline): CA7P5EPYKC2IW4PCMAH6NRBLHH3WP7AN6WWC3QDRWO4HLE47FAGO6TET
NEXT_PUBLIC_SOROBAN_CONTRACT_ID=

# Wallet address that controls admin-only trust actions such as approving or
# suspending issuers in the Phase 1 trust layer UI.
NEXT_PUBLIC_STELLAR_ADMIN_ADDRESS=

# A funded testnet account used only for simulating read-only contract calls.
# Fund any Stellar G... address at https://friendbot.stellar.org/
NEXT_PUBLIC_STELLAR_READ_ADDRESS=

NEXT_PUBLIC_SOROBAN_ASSET_ADDRESS=
NEXT_PUBLIC_SOROBAN_ASSET_CODE=XLM
NEXT_PUBLIC_SOROBAN_ASSET_DECIMALS=7

NEXT_PUBLIC_STELLAR_EXPLORER_URL=https://stellar.expert/explorer/testnet

# Public canonical origin used by SEO metadata and internal URL validation.
# Keep this as your canonical production domain.
NEXT_PUBLIC_CANONICAL_URL=https://stellaroid.tech

# Fee sponsorship is disabled for public browser clients by default.
# Only enable for trusted server-to-server callers with a bearer token.
# FEE_SPONSOR_SECRET=S...
# FEE_SPONSOR_TOKEN=generate-a-long-random-server-token
# NEXT_PUBLIC_FEE_SPONSOR_ADDRESS=G...
